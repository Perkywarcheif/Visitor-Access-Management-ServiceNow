        <script><![CDATA[(function executeRule(current, previous) {

    var log = new GlideRecord('x_2065649_visito_0_visitor_log');
    log.initialize();

    log.visitor_request = current.sys_id;
    log.timestamp = new GlideDateTime();
    log.performed_by = gs.getUserID();

    if (current.state == 'approved') {

        log.action = 'approved';
        log.notes = 'Visitor request approved';

        current.approved_by = gs.getUserID();
        current.update();
    }

    else if (current.state == 'checked_in') {

        log.action = 'check_in';
        log.notes = 'Visitor checked in';

        current.checked_in_time = new GlideDateTime();
        current.update();
    }

    else if (current.state == 'checked_out') {

        log.action = 'check_out';
        log.notes = 'Visitor checked out';
    }

    else {
        return;
    }

    log.insert();

})(current, previous);]]></script>
